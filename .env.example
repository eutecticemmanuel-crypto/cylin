# Server Configuration
PORT=3000
NODE_ENV=production

# MongoDB Configuration
MONGODB_URI=mongodb+srv://<DB_USER>:<DB_PASSWORD>@cluster0.8fml9ow.mongodb.net/cylin-painters?retryWrites=true&w=majority
DB_USER=your_mongodb_username
DB_PASSWORD=your_mongodb_password
